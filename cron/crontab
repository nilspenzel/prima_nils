# Cron job to run full backup script every hour
0 * * * * /usr/local/bin/node /app/scripts/fullBackup.js >> /var/log/cron.log 2>&1

# Cron job to run anonymize script every month on the 21st at 3:00 AM
* 3 21 * * /usr/local/bin/node /app/scripts/anonymize.js >> /var/log/cron.log 2>&1

# Cron job to notify customers if vehicle which picks them up changes
* * * * * /usr/local/bin/node /app/scripts/sendNewVehicleNotice.js >> /var/log/cron.log 2>&1

# Cron job to remind customers and companies of imminent journeys
*/5 * * * * /usr/local/bin/node /app/scripts/sendReminder.js >> /var/log/cron.log 2>&1

# Cron job to anonymize taxi related data
30 3 1 * * /usr/local/bin/node /app/scripts/anonymize.js --type=taxi >> /var/log/cron.log 2>&1

# Cron job to anonymize ride sharing related data
0 4 * * 1 /usr/local/bin/node /app/scripts/anonymize.js --type=rs >> /var/log/cron.log 2>&1

# Cron job to clean up unused event groups
30 4 * * * /usr/local/bin/node /app/scripts/deleteUnusedEventGroups.js >> /var/log/cron.log 2>&1
